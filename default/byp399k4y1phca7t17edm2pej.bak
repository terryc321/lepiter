				"code" : "lines collect: [ :line | \r |ig in props p1 p2 dict|\r   dict := Dictionary new.\r   ig := line splitOn: Character space .\r   (ig splitOn: $:) collect: [:e | \r       | words dict sue x y z nx ny nz |\r       dict := Dictionary new.\r       words := OrderedCollection new.\r        e do:[ :s |\r         words add: (s reject:[:c | c = $: or: [c = $,]])].\r         sue := (words at: 2) asInteger.\r         x := (words at: 3) asSymbol.\r         y := (words at: 5) asSymbol.\r         z := (words at: 7) asSymbol.\r         nx := (words at: 4) asInteger.\r         ny := (words at: 6) asInteger.\r         nz := (words at: 8) asInteger.\r         dict at: #sue put: sue.\r         dict at: x put: nx.\r         dict at: y put: ny.\r         dict at: z put: nz.\r         words.\r         dict.\r          ]]."
			},
