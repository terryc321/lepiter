				"code" : "\"children: 3  -- 1\ncats: 7       -- 2\nsamoyeds: 2   -- 3\npomeranians: 3 -- 4\nakitas: 0  ------ 5\nvizslas: 0  ----- 6\ngoldfish: 5 ----- 7\ntrees: 3 -------- 8\ncars: 2 --------- 9\nperfumes: 1   --- 10\"\rdata1 := aoc \r filter: data with: [:dict | | s n | s:= #children. n := 3 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .\rdata2 := aoc   \r filter: data1 with: [:dict | | s n | s:= #cats. n := 7 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .\rdata3 := aoc     \r filter: data2 with: [:dict | | s n | s:= #samoyeds. n := 2 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .\rdata4 := aoc     \r filter: data3 with: [:dict | | s n | s:= #pomeranians. n := 3 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .\rdata5 := aoc     \r filter: data4 with: [:dict | | s n | s:= #akitas. n := 0 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .\rdata6 := aoc     \r filter: data5 with: [:dict | | s n | s:= #vizslas. n := 0 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .     \rdata7 := aoc     \r filter: data6 with: [:dict | | s n | s:= #goldfish. n := 5 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .     \rdata8 := aoc     \r filter: data7 with: [:dict | | s n | s:= #trees. n := 3 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .     \rdata9 := aoc     \r filter: data8 with: [:dict | | s n | s:= #cars. n := 2 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .     \rdata10 := aoc     \r filter: data8 with: [:dict | | s n | s:= #perfumes.  n := 1 .\r     dict at: s ifPresent:[ | k | k := dict at: s. n = k] ifAbsent: [ true ]] .    \r          \r          \r          \r          "
