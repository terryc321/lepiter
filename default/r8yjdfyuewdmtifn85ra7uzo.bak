					"uidString" : "WAVvvvWGThSSw+PJPLlY9Q=="
				},
				"code" : "\"all ways can make a certain number #(20 15 10 5 5) for 25 litres \"\r| arr sz target |\rtarget := 25.\rarr := aoc example.\rsz := arr size.\racc := OrderedCollection new.\r\"one\"\r(1 to: sz) do:[:ai | \r       a := arr at: ai.\r       a = target ifTrue: [ acc add: { a }  ]].\r\r\"two\"\r(1 to: sz) do:[:ai | \r  ((ai + 1) to: sz) do:[:bi | \r      a := arr at: ai.\r      b := arr at: bi.\r     (a + b) = target ifTrue: [ acc add: { a . b }  ]]].\r\r\"three\"\r(1 to: sz) do:[:ai | \r  ((ai + 1) to: sz) do:[:bi | \r   ((bi + 1) to: sz) do:[:ci | \r      a := arr at: ai.\r      b := arr at: bi.\r      c := arr at: ci.\r     ((a + b)+c) = target ifTrue: [ acc add: { a . b .c }  ]]]].\r\r\"four\"     \r(1 to: sz) do:[:ai | \r  ((ai + 1) to: sz) do:[:bi | \r   ((bi + 1) to: sz) do:[:ci | \r   ((ci + 1) to: sz) do:[:di | \r      a := arr at: ai.\r      b := arr at: bi.\r      c := arr at: ci.\r      d := arr at: di.\r     (((a + b)+c)+d) = target ifTrue: [ acc add: { a . b . c . d }  ]]]]].\r     \r\"five\"     \r(1 to: sz) do:[:ai | \r  ((ai + 1) to: sz) do:[:bi | \r   ((bi + 1) to: sz) do:[:ci | \r   ((ci + 1) to: sz) do:[:di | \r   ((di + 1) to: sz) do:[:ei | \r      a := arr at: ai.\r      b := arr at: bi.\r      c := arr at: ci.\r      d := arr at: di.\r      e := arr at: ei.\r     ((((a + b)+c)+d)+e) = target ifTrue: [ acc add: { a . b . c . d . e}  ]]]]]].\r          \r     acc.     "
			},
